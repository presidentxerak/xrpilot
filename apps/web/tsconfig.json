{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@pilot/ui": ["../../packages/ui/src"],
      "@pilot/shared": ["../../packages/shared/src"],
      "@pilot/design-tokens": ["../../packages/design-tokens/src"],
      "@pilot/wallet-core": ["../../packages/wallet-core/src"],
      "@pilot/xrpl-client": ["../../packages/xrpl-client/src"],
      "@pilot/security": ["../../packages/security/src"],
      "@pilot/objects-engine": ["../../packages/objects-engine/src"],
      "@pilot/analytics": ["../../packages/analytics/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
